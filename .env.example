# XAUUSD Signal Engine - Environment Variables

# Required: Telegram Bot
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Required: OpenAI API
OPENAI_API_KEY=your_openai_api_key

# Optional: AI Model (default: gpt-4o-mini)
AI_MODEL=gpt-4o-mini

# Optional: Webhook server
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# Optional: Risk parameters
MAX_SL_PIPS=100
MIN_RR=1.0
SPREAD_THRESHOLD_PIPS=5.0

# Optional: Signal cooldown (seconds)
SIGNAL_COOLDOWN=900

# Optional: Database path
DB_PATH=signals.db

# Optional: Log level
LOG_LEVEL=INFO
